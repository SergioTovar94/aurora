---
interface Props {
  href?: string;
  variant?: "primary" | "secondary";
}

const { href = "#", variant = "primary" } = Astro.props as Props;

const styles = {
  primary: "bg-white text-black hover:scale-105",

  secondary: "border border-zinc-700 hover:border-zinc-500",
};
---

<a
  href={href}
  class={`rounded-xl px-6 py-3 font-semibold transition ${styles[variant]}`}
>
  <slot />
</a>
