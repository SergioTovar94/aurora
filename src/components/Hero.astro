---
import Button from "./Button.astro";
---

<section class="flex min-h-screen items-center pt-24">
  <div class="mx-auto max-w-6xl px-6">
    <p class="mb-4 text-sm uppercase tracking-[0.3em] text-zinc-400">
      Desarrollo de Software
    </p>

    <h1 class="max-w-3xl text-5xl font-black leading-tight md:text-7xl">
      Construimos software rápido, moderno y escalable.
    </h1>

    <p class="mt-6 max-w-2xl text-lg text-zinc-400">
      Desarrollo aplicaciones web, APIs y soluciones digitales enfocadas en
      rendimiento, arquitectura y experiencia de usuario.
    </p>

    <div class="mt-10 flex gap-4">
      <Button href="#contact"> Contactarme </Button>

      <Button href="#services" variant="secondary"> Ver servicios </Button>
    </div>
  </div>
</section>
