---
import Container from "./Container.astro";
---

<footer id="footer" class="border-t border-zinc-800 bg-[#010214]">
  <Container>
    <div
      class="flex flex-col gap-10 py-12 md:flex-row md:items-start md:justify-between"
    >
      <!-- Brand -->
      <div class="max-w-sm">
        <div class="flex items-center gap-3">
          <img
            src="/horizontal.png"
            alt="Aurora Logo"
            class="h-12 w-auto object-contain"
          />
        </div>

        <p class="mt-3 text-sm text-zinc-500">
          Desarrollo de software moderno y escalable enfocado en experiencias
          digitales limpias y eficientes.
        </p>
      </div>

      <!-- Links -->
      <div class="flex flex-col gap-3 text-sm text-zinc-400">
        <a href="#services" class="hover:text-white transition">Servicios</a>
        <a href="#tech" class="hover:text-white transition">Tecnologías</a>
        <a href="#contact" class="hover:text-white transition">Contacto</a>
      </div>

      <!-- Contacto + redes -->
      <div class="flex flex-col gap-4 text-sm text-zinc-400">
        <a
          href="mailto:sergiotovar9430@gmail.com"
          class="hover:text-white transition"
        >
          Correo Aurora
        </a>

        <!-- Redes -->
        <div class="flex items-center gap-4 text-zinc-400">
          <a
            href="https://www.instagram.com/aurorawebst/"
            class="hover:text-white transition"
            aria-label="Instagram"
          >
            Instagram
          </a>

          <a
            href="https://www.linkedin.com/company/aurorawebst/?viewAsMember=true"
            class="hover:text-white transition"
            aria-label="LinkedIn"
          >
            LinkedIn
          </a>

          <a
            href="https://www.facebook.com/aurorawebst/"
            class="hover:text-white transition"
            aria-label="Facebook"
          >
            Facebook
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom -->
    <div class="border-t border-zinc-800 py-6">
      <p class="text-center text-xs text-zinc-600">
        © {new Date().getFullYear()} Aurora Web Studio. Todos los derechos reservados.
      </p>
    </div>
  </Container>
</footer>
